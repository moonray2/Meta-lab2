                    <h5>Статистика обработанных данных</h5>
                    <ul>
                        <li>Количество точек: ${results.dataPoints}</li>
                        <li>Максимальная деформация: ${(results.maxStrain * 100).toFixed(2)}%</li>
                        <li>Коэффициент корреляции R² для E: ${calculateRSquared(data, results.elasticModulus).toFixed(4)}</li>
                    </ul>
                </div>
                <div class="detail-section">
                    <h5>Проверка по критериям ГОСТ</h5>
                    <ul>
                        <li>Скорость деформирования: рекомендуется 0.00025 с⁻¹ до предела текучести</li>
                        <li>Соотношение l₀/d₀: ${(results.l0 / Math.sqrt(4 * results.F0 / Math.PI)).toFixed(2)} (норма: 5.65 для пропорциональных)</li>
                    </ul>
                </div>
            `;
            
            document.getElementById('calculationDetails').innerHTML = html;
        }
        
        function calculateRSquared(data, E) {
            const elasticRegion = data.filter(p => p.stress < E * 0.002);
            if (elasticRegion.length < 5) return 0;
            
            const meanStress = elasticRegion.reduce((sum, p) => sum + p.stress, 0) / elasticRegion.length;
            let ssRes = 0, ssTot = 0;
            
            elasticRegion.forEach(p => {
                const predicted = E * p.strain;
                ssRes += Math.pow(p.stress - predicted, 2);
                ssTot += Math.pow(p.stress - meanStress, 2);
            });
            
            return 1 - (ssRes / ssTot);
        }
        
