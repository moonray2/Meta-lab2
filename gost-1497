    <script src="script.js"></script>
    <script>
        // Глобальные переменные
        let currentRawData = null;
        let currentProcessedData = null;
        let currentResults = null;
        let chartInstance = null;
        
        // Инициализация
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('csvFile').addEventListener('change', handleFileUpload);
            document.getElementById('analyzeBtn').addEventListener('click', performFullAnalysis);
            document.getElementById('calcProtocolBtn').addEventListener('click', generateGOSTProtocol);
            document.getElementById('saveProtocolBtn').addEventListener('click', saveCurrentProtocol);
            document.getElementById('exportWordBtn').addEventListener('click', exportToWord);
            document.getElementById('exportExcelBtn').addEventListener('click', exportToExcel);
            document.getElementById('specType').addEventListener('change', toggleSpecimenFields);
            
            // Вкладки
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', () => switchTab(btn.dataset.tab));
            });
            
            toggleSpecimenFields();
        });
        
        function toggleSpecimenFields() {
            const type = document.getElementById('specType').value;
            document.getElementById('roundFields').style.display = type === 'round' ? 'block' : 'none';
            document.getElementById('flatFields').style.display = type === 'flat' ? 'block' : 'none';
            document.getElementById('neckFields').style.display = type === 'round' ? 'block' : 'none';
        }
        
        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(tabName + 'Tab').style.display = 'block';
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');
        }
        
        // Обработка загрузки файла
        function handleFileUpload(e) {
            const file = e.target.files[0];
            if (!file) return;
            
            document.getElementById('fileStatus').innerHTML = `📁 ${file.name} (загрузка...)`;
            const ext = file.name.split('.').pop().toLowerCase();
            const reader = new FileReader();
            
            reader.onload = (ev) => {
                let rawData = [];
                
                if (ext === 'csv' || ext === 'txt') {
                    const text = ev.target.result;
                    const lines = text.split(/\r?\n/);
                    let headerSkipped = false;
                    
                    for (let line of lines) {
                        line = line.trim();
                        if (!line) continue;
                        
                        // Пропускаем заголовки с буквами
                        if (!headerSkipped && /[а-яА-Яa-zA-Z]/.test(line)) {
                            headerSkipped = true;
                            continue;
                        }
                        
                        const parts = line.split(/[ ,;\t]+/);
                        if (parts.length >= 2) {
                            const x = parseFloat(parts[0].replace(',', '.'));
                            const y = parseFloat(parts[1].replace(',', '.'));
                            if (!isNaN(x) && !isNaN(y) && y > 0) {
                                rawData.push({ strain: x, force: y });
                            }
                        }
                    }
                } else {
                    const workbook = XLSX.read(ev.target.result, { type: 'binary' });
                    const sheet = workbook.Sheets[workbook.SheetNames[0]];
                    const rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });
                    
                    for (let row of rows) {
                        if (!row || row.length < 2) continue;
                        const x = parseFloat(row[0]);
                        const y = parseFloat(row[1]);
                        if (!isNaN(x) && !isNaN(y) && y > 0) {
                            rawData.push({ strain: x, force: y });
                        }
                    }
                }
                
                if (rawData.length < 10) {
                    alert("Ошибка: недостаточно данных. Минимум 10 точек.");
                    document.getElementById('fileStatus').innerHTML = `❌ Ошибка загрузки`;
                    return;
                }
                
                currentRawData = rawData;
                document.getElementById('fileStatus').innerHTML = `✅ ${file.name} (${rawData.length} точек)`;
            };
            
            if (ext === 'csv' || ext === 'txt') {
                reader.readAsText(file, 'UTF-8');
            } else {
                reader.readAsBinaryString(file);
            }
        }
        
        // ===== ОСНОВНОЙ РАСЧЕТ ПО ГОСТ 1497-2023 =====
        function performFullAnalysis() {
            if (!currentRawData || currentRawData.length < 10) {
                alert("Сначала загрузите корректный файл с данными");
                return;
            }
            
            // Получаем параметры образца
            const F0 = calculateInitialArea();
            if (F0 <= 0) {
                alert("Введите корректные размеры образца");
                return;
            }
            
            const l0 = parseFloat(document.getElementById('l0').value);
            const gaugeBase = parseFloat(document.getElementById('gaugeBase').value);
            const compliance = parseFloat(document.getElementById('compliance').value);
            const expectedE = parseFloat(document.getElementById('expectedE').value) * 1000; // ГПа -> МПа
            
            // Шаг 1: Фильтрация и сортировка данных
            let data = [...currentRawData].sort((a, b) => a.strain - b.strain);
            
            // Удаление начального люфта
            data = removeInitialSlack(data);
            
            // Коррекция податливости
            if (compliance > 0) {
                data = correctCompliance(data, compliance);
            }
            
            // Шаг 2: Расчет напряжений и деформаций
            const processedData = data.map(point => {
                // Пересчет перемещения в относительную деформацию
                const strain = point.strain / gaugeBase;
                const stress = point.force / F0; // МПа
                return {
                    strain: strain,
                    stress: stress,
                    force: point.force,
                    displacement: point.strain
                };
            });
            
            currentProcessedData = processedData;
            
            // Шаг 3: Определение модуля упругости E (по ГОСТ 1497, п. 7.4)
            const elasticModulus = calculateElasticModulus(processedData, expectedE);
            
            // Шаг 4: Определение предела текучести физического σт
            const yieldPhysical = findPhysicalYieldPoint(processedData);
            
            // Шаг 5: Определение условного предела текучести σ₀.₂ (метод параллельного смещения)
            const yieldOffset02 = calculateOffsetYield(processedData, elasticModulus, 0.002);
            
            // Шаг 6: Определение временного сопротивления σв
            const tensileStrength = calculateTensileStrength(processedData);
            
            // Шаг 7: Определение характеристик пластичности
            const lk = parseFloat(document.getElementById('lk').value);
            const delta = ((lk - l0) / l0) * 100;
            
            let psi = null;
            const specType = document.getElementById('specType').value;
            if (specType === 'round') {
                const dk = parseFloat(document.getElementById('dk').value);
                if (dk > 0) {
                    const Fk = Math.PI * dk * dk / 4;
                    psi = ((F0 - Fk) / F0) * 100;
                }
            }
            
            // Шаг 8: Определение предела текучести для протокола (по ГОСТ)
            let yieldStrength, yieldType;
            if (yieldPhysical.hasYield) {
                yieldStrength = yieldPhysical.lowerYield;
                yieldType = "σтн (физический нижний)";
            } else {
                yieldStrength = yieldOffset02;
                yieldType = "σ₀.₂ (условный)";
            }
            
            // Сохраняем результаты
            currentResults = {
                // Основные характеристики
                sigmaB: tensileStrength.maxStress,
                sigmaT: yieldStrength,
                yieldType: yieldType,
                sigma02: yieldOffset02,
                elasticModulus: elasticModulus,
                delta: delta,
                psi: psi,
                
                // Дополнительные данные
                F0: F0,
                l0: l0,
                lk: lk,
                Pmax: tensileStrength.maxForce,
                
                // Данные о текучести
                yieldUpper: yieldPhysical.upperYield,
                yieldLower: yieldPhysical.lowerYield,
                hasPhysicalYield: yieldPhysical.hasYield,
                
                // Параметры для графика
                elasticLine: {
                    slope: elasticModulus,
                    points: calculateElasticLine(processedData, elasticModulus)
                },
                offsetLine: {
                    slope: elasticModulus,
                    intercept: -elasticModulus * 0.002
                },
                
                // Статистика
                dataPoints: processedData.length,
                maxStrain: Math.max(...processedData.map(p => p.strain))
            };
            
            // Отображение результатов
            displayResults(currentResults);
            drawStressStrainChart(processedData, currentResults);
            displayCalculationDetails(currentResults, processedData, yieldPhysical);
            
            // Автозаполнение Pmax для ручного режима
            document.getElementById('manualPmax') && (document.getElementById('manualPmax').value = currentResults.Pmax);
            
            // Переключаем на вкладку результатов
            switchTab('results');
        }
        
        // Вспомогательные функции расчета
        function calculateInitialArea() {
            const type = document.getElementById('specType').value;
            if (type === 'round') {
                const d = parseFloat(document.getElementById('d0').value);
                return Math.PI * d * d / 4;
            } else {
                const a = parseFloat(document.getElementById('a0').value);
                const b = parseFloat(document.getElementById('b0').value);
                return a * b;
            }
        }
        
        function removeInitialSlack(data) {
            // Находим точку, где сила начинает устойчиво расти
            const threshold = Math.max(...data.map(p => p.force)) * 0.01;
            let startIndex = 0;
            
            for (let i = 5; i < data.length - 5; i++) {
                const avgNext = data.slice(i, i + 5).reduce((sum, p) => sum + p.force, 0) / 5;
                if (avgNext > threshold) {
                    startIndex = Math.max(0, i - 5);
                    break;
                }
            }
            
            const shiftedData = data.slice(startIndex);
            const minStrain = shiftedData[0].strain;
            
            return shiftedData.map(p => ({
                strain: p.strain - minStrain,
                force: p.force
            }));
        }
        
        function correctCompliance(data, compliance) {
            // Коррекция податливости: ε_ист = ε_изм - Cм·F
            return data.map(p => ({
                strain: Math.max(0, p.strain - compliance * p.force / 1000), // compliance в мм/кН
                force: p.force
            }));
        }
        
        function calculateElasticModulus(data, expectedE) {
            // По ГОСТ 1497: определение E в диапазоне 0.1-0.3 от ожидаемого σ₀.₂
            const maxStress = Math.max(...data.map(p => p.stress));
            const stressLimit = Math.min(maxStress * 0.3, expectedE * 0.001); // примерно до 0.1% деформации
            
            const elasticRegion = data.filter(p => p.stress < stressLimit && p.stress > stressLimit * 0.1);
            
            if (elasticRegion.length < 10) {
                return expectedE; // Возвращаем ожидаемое значение
            }
            
            // Линейная регрессия
            let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
            const n = elasticRegion.length;
            
            elasticRegion.forEach(p => {
                sumX += p.strain;
                sumY += p.stress;
                sumXY += p.strain * p.stress;
                sumX2 += p.strain * p.strain;
            });
            
            const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
            
            // Проверка на адекватность
            if (slope < expectedE * 0.5 || slope > expectedE * 1.5) {
                return expectedE;
            }
            
            return slope;
        }
        
        function findPhysicalYieldPoint(data) {
            // Поиск зуба текучести по ГОСТ 1497
            let maxStress = 0;
            let maxIndex = 0;
            
            // Находим первый максимум (верхний предел текучести)
            for (let i = 1; i < data.length - 1; i++) {
                if (data[i].stress > maxStress && 
                    data[i].stress > data[i-1].stress && 
                    data[i].stress > data[i+1].stress) {
                    maxStress = data[i].stress;
                    maxIndex = i;
                    break; // Берем первый пик
                }
            }
            
            if (maxStress === 0) {
                return { hasYield: false, upperYield: null, lowerYield: null };
            }
            
            // Ищем нижний предел текучести (минимум после пика)
            let minStress = maxStress;
            let minIndex = maxIndex;
            
            for (let i = maxIndex + 1; i < Math.min(data.length, maxIndex + 100); i++) {
                if (data[i].stress < minStress) {
                    minStress = data[i].stress;
                    minIndex = i;
                }
                // Выходим, если напряжение снова начало расти
                if (data[i].stress > minStress * 1.02 && i > minIndex + 5) {
                    break;
                }
            }
            
            // Проверяем, является ли это реальной площадкой текучести
            const dropRatio = (maxStress - minStress) / maxStress;
            const hasYield = dropRatio > 0.02 && (minIndex - maxIndex) > 3;
            
            return {
                hasYield: hasYield,
                upperYield: hasYield ? maxStress : null,
                lowerYield: hasYield ? minStress : null,
                upperIndex: maxIndex,
                lowerIndex: minIndex
            };
        }
        
        function calculateOffsetYield(data, E, offset = 0.002) {
            // Метод параллельного смещения для σ₀.₂
            // Линия: σ = E * (ε - offset)
            
            // Находим пересечение с кривой
            const offsetLine = (strain) => E * (strain - offset);
            
            for (let i = 0; i < data.length; i++) {
                const lineStress = offsetLine(data[i].strain);
                if (data[i].stress >= lineStress) {
                    // Линейная интерполяция для точности
                    if (i > 0) {
                        const prevLine = offsetLine(data[i-1].strain);
                        const prevStress = data[i-1].stress;
                        const currLine = lineStress;
                        const currStress = data[i].stress;
                        
                        const ratio = (prevStress - prevLine) / ((prevStress - prevLine) - (currStress - currLine));
                        const exactStrain = data[i-1].strain + ratio * (data[i].strain - data[i-1].strain);
                        const exactStress = offsetLine(exactStrain);
                        
                        return exactStress;
                    }
                    return data[i].stress;
                }
            }
            
            return data[data.length - 1].stress * 0.8; // Запасной вариант
        }
        
        function calculateTensileStrength(data) {
            let maxStress = 0;
            let maxForce = 0;
            
            data.forEach(point => {
                if (point.stress > maxStress) {
                    maxStress = point.stress;
                    maxForce = point.force;
                }
            });
            
            return { maxStress, maxForce };
        }
        
        function calculateElasticLine(data, E) {
            const points = [];
            const maxStrain = Math.min(0.005, data[Math.floor(data.length * 0.1)].strain);
            
            for (let e = 0; e <= maxStrain; e += maxStrain / 20) {
                points.push({ strain: e, stress: E * e });
            }
            
            return points;
        }
        
        // Отображение результатов
        function displayResults(results) {
            const html = `
                <div class="result-card">
                    <h3>📊 Результаты испытания по ГОСТ 1497-2023</h3>
                    <table class="results-table">
                        <tr><th colspan="2">Прочностные характеристики</th></tr>
                        <tr><td>Временное сопротивление σв</td><td><strong>${Math.round(results.sigmaB)} МПа</strong></td></tr>
                        <tr><td>Предел текучести ${results.yieldType}</td><td><strong>${Math.round(results.sigmaT)} МПа</strong></td></tr>
                        <tr><td>Условный предел текучести σ₀.₂</td><td>${Math.round(results.sigma02)} МПа</td></tr>
                        ${results.hasPhysicalYield ? `
                        <tr><td>Верхний предел текучести σтв</td><td>${Math.round(results.yieldUpper)} МПа</td></tr>
                        <tr><td>Нижний предел текучести σтн</td><td>${Math.round(results.yieldLower)} МПа</td></tr>
                        ` : ''}
                        <tr><th colspan="2">Упругие свойства</th></tr>
                        <tr><td>Модуль упругости E</td><td><strong>${Math.round(results.elasticModulus / 1000)} ГПа</strong></td></tr>
                        <tr><th colspan="2">Пластичность</th></tr>
                        <tr><td>Относительное удлинение δ</td><td><strong>${results.delta.toFixed(1)}%</strong></td></tr>
                        ${results.psi ? `<tr><td>Относительное сужение ψ</td><td><strong>${results.psi.toFixed(1)}%</strong></td></tr>` : ''}
                        <tr><th colspan="2">Геометрия образца</th></tr>
                        <tr><td>Начальная площадь F₀</td><td>${results.F0.toFixed(2)} мм²</td></tr>
                        <tr><td>Максимальное усилие Pmax</td><td>${Math.round(results.Pmax)} Н</td></tr>
                    </table>
                    <div class="result-note">
                        ${results.hasPhysicalYield ? 
                            '✅ Обнаружена физическая площадка текучести' : 
                            '⚠️ Площадка текучести не обнаружена, используется σ₀.₂'}
                    </div>
                </div>
            `;
            
            document.getElementById('autoResults').innerHTML = html;
        }
        
        function drawStressStrainChart(data, results) {
            const ctx = document.getElementById('stressStrainChart').getContext('2d');
            
            if (chartInstance) {
                chartInstance.destroy();
            }
            
            // Подготовка данных
            const strains = data.map(p => p.strain * 100); // в %
            const stresses = data.map(p => p.stress);
            
            // Линия упругости
            const elasticStrains = results.elasticLine.points.map(p => p.strain * 100);
            const elasticStresses = results.elasticLine.points.map(p => p.stress);
            
            // Линия 0.2% смещения
            const offsetStrains = strains.filter(e => e > 0.1 && e < 1.0);
            const offsetStresses = offsetStrains.map(e => results.elasticModulus * (e/100 - 0.002));
            
            chartInstance = new Chart(ctx, {
                type: 'scatter',
                data: {
                    datasets: [{
                        label: 'Кривая растяжения',
                        data: strains.map((x, i) => ({ x, y: stresses[i] })),
