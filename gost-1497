                            max: Math.min(5, results.maxStrain * 100)
                        },
                        y: {
                            title: {
                                display: true,
                                text: 'Напряжение σ, МПа'
                            },
                            min: 0,
                            max: Math.min(results.sigmaB * 1.1, results.sigmaB + 200)
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: (context) => {
                                    return `σ = ${context.parsed.y.toFixed(1)} МПа, ε = ${context.parsed.x.toFixed(3)}%`;
                                }
                            }
                        },
                        annotation: {
                            annotations: {
                                yieldPoint: results.hasPhysicalYield ? {
                                    type: 'point',
                                    xValue: data[results.yieldLower?.index]?.strain * 100,
                                    yValue: results.yieldLower,
                                    backgroundColor: 'rgba(255, 159, 64, 0.7)',
                                    radius: 5
                                } : null,
                                sigma02: {
                                    type: 'point',
                                    xValue: 0.2 + results.sigma02 / results.elasticModulus * 100,
                                    yValue: results.sigma02,
                                    backgroundColor: 'rgba(220, 53, 69, 0.7)',
                                    radius: 5
                                },
                                sigmaB: {
                                    type: 'point',
                                    xValue: data.find(p => p.stress === results.sigmaB)?.strain * 100,
                                    yValue: results.sigmaB,
                                    backgroundColor: 'rgba(30, 58, 95, 0.7)',
                                    radius: 5
                                }
                            }
                        }
                    }
                }
            });
        }
        
        function displayCalculationDetails(results, data, yieldPhysical) {
            let html = `
                <h4>🔬 Детализация расчета по ГОСТ 1497-2023</h4>
                <div class="detail-section">
                    <h5>Методика определения характеристик</h5>
                    <ul>
                        <li><strong>Модуль упругости E:</strong> определен методом линейной регрессии на участке 0.1-0.3 от σ₀.₂</li>
                        <li><strong>Условный предел текучести σ₀.₂:</strong> метод параллельного смещения на 0.2%</li>
                        <li><strong>Физический предел текучести:</strong> ${yieldPhysical.hasYield ? 
                            'определен по максимуму и последующему минимуму на площадке текучести' : 
                            'не обнаружен'}</li>
                    </ul>
                </div>
